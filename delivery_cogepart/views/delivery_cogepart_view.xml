<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_delivery_carrier_cogepart_form" model="ir.ui.view">
        <field name="name">delivery.carrier.cogepart.form</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <div invisible="delivery_type != 'cogepart'">
                    <group string="Configuration Cogepart">
                        <field name="cogepart_login"/>
                        <field name="cogepart_password" password="True"/>
                        <field name="cogepart_siret"/>
                        <field name="cogepart_api_url"/>
                    </group>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
